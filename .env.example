# Chat provider: ollama (recommended locally) | gemini (tries Gemini first)
CHAT_PROVIDER=ollama
USE_OLLAMA_ONLY=true

# Optional Gemini (only if CHAT_PROVIDER=gemini and network works)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama — you have phi3:mini, gemma:2b, mistral:7b, llama3 installed
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma:2b
OLLAMA_TIMEOUT_MS=180000

NEXT_PUBLIC_INCIDENT_PLATFORM_URL=http://localhost:3000
